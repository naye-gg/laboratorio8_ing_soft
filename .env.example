# Plantilla de variables de entorno. Copiala a .env y completa los valores:
#   cp .env.example .env   &&   editar .env
# .env contiene secretos y NO se versiona.

# RabbitMQ
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USER=students
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/

# Kafka (opcional)
KAFKA_BOOTSTRAP=

# SonarQube (token de analisis del proyecto)
SONAR_TOKEN=
